# PostgreSQL is required for persisted CRM mode. Keep real credentials in .env.local.
DATABASE_URL=postgresql://username:password@localhost:5432/aura_crm?sslmode=require

# Set true for managed PostgreSQL providers that require TLS.
PGSSL=true

# Optional: use a separate database for integration tests.
DATABASE_URL_TEST=

# Optional NVIDIA Nemotron provider. Never commit a real key.
NVIDIA_API_KEY=
